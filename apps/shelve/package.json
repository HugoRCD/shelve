{
  "name": "@shelve/app",
  "description": "Shelve is a project management tool for developers teams",
  "private": true,
  "type": "module",
  "repository": "https://github.com/HugoRCD/shelve",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "db:check:pre": "node scripts/migration-checks.mjs --mode=pre",
    "db:check:post": "node scripts/migration-checks.mjs --mode=post",
    "migration:db-reset": "node scripts/migration-db-reset.mjs",
    "migration:seed": "node scripts/migration-seed.mjs",
    "migration:verify": "node scripts/migration-verify.mjs",
    "migration:cli-check": "node scripts/migration-cli-check.mjs",
    "migration:phase-check": "node scripts/migration-phase-check.mjs",
    "migration:rehearsal": "node scripts/migration-rehearsal.mjs",
    "migration:rehearsal:phase0": "node scripts/migration-rehearsal.mjs --phase=0",
    "migration:rehearsal:phase1": "node scripts/migration-rehearsal.mjs --phase=1",
    "migration:rehearsal:phase2": "node scripts/migration-rehearsal.mjs --phase=2",
    "migration:rehearsal:phase3": "node scripts/migration-rehearsal.mjs --phase=3",
    "migration:rehearsal:phase4": "node scripts/migration-rehearsal.mjs --phase=4",
    "migration:rehearsal:phase5": "node scripts/migration-rehearsal.mjs --phase=5",
    "migration:rehearsal:phase6": "node scripts/migration-rehearsal.mjs --phase=6",
    "migration:snapshot": "node scripts/migration-snapshot.mjs",
    "migration:compare": "node scripts/migration-compare.mjs",
    "db:generate": "SKIP_ENV_VALIDATION=1 nuxt db generate",
    "db:migrate": "SKIP_ENV_VALIDATION=1 nuxt db migrate"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@onmax/nuxt-better-auth": "https://pkg.pr.new/nuxt-modules/better-auth/@onmax/nuxt-better-auth@165",
    "@vue-email/components": "^0.0.21",
    "@vue-email/render": "^0.0.9",
    "better-auth": "^1.5.0-beta.15",
    "blakejs": "^1.2.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "jsonwebtoken": "^9.0.3",
    "libsodium-wrappers": "^0.8.2",
    "nuxt-build-cache": "^0.1.1",
    "postgres": "^3.4.8",
    "resend": "^6.9.1",
    "tweetnacl": "^1.0.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.1.1",
    "@playwright/test": "^1.50.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/libsodium-wrappers": "^0.8.2"
  }
}
